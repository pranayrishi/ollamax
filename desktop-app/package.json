{
  "name": "ollama-forge-app",
  "productName": "Ollamax",
  "version": "0.3.0",
  "description": "Local-first AI coding — a standalone desktop app with Agent and controlled Team workflows on your own hardware via local Ollama.",
  "author": "Ollamax",
  "license": "MIT",
  "homepage": "https://github.com/pranayrishi/ollamax-releases",
  "main": "main.js",
  "private": true,
  "scripts": {
    "prepare-assets": "node scripts/prepare.mjs",
    "test": "node --test companion/protocol.test.js",
    "start": "npm run prepare-assets && electron .",
    "dist": "npm run prepare-assets && electron-builder",
    "dist:mac": "npm run prepare-assets && electron-builder --mac",
    "dist:win": "npm run prepare-assets && electron-builder --win",
    "dist:linux": "npm run prepare-assets && electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "@electron/fuses": "^1.8.0"
  },
  "dependencies": {
    "monaco-editor": "^0.52.0",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0"
  },
  "//note": "node-pty (the terminal backend) is a NATIVE module that needs a per-platform toolchain (it broke CI on macOS distutils + Windows VS detection). It is intentionally NOT a build dependency yet — the app ships without it and the terminal panel degrades gracefully (ide.js shows an install hint). To enable the terminal locally: `npm install node-pty` then `npm run dist`. Re-adding it to the release needs the native build sorted per-OS.",
  "build": {
    "appId": "com.ollamax.app",
    "productName": "Ollamax",
    "files": [
      "main.js",
      "preload.js",
      "companion/**/*",
      "renderer/**/*",
      "package.json",
      "!**/*.map"
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "extraResources": [
      { "from": "assets/", "to": "assets/" },
      { "from": "bin/", "to": "bin/" }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "artifactName": "Ollamax-macos-${arch}.${ext}",
      "target": [
        { "target": "dmg", "arch": ["arm64"] },
        { "target": "zip", "arch": ["arm64"] }
      ],
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "identity": null,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "artifactName": "Ollamax-linux-${arch}.${ext}",
      "icon": "assets/icon.png",
      "maintainer": "Ollamax <74742835+pranayrishi@users.noreply.github.com>",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "category": "Development"
    },
    "nsis": {
      "artifactName": "Ollamax-windows-${arch}-setup.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "Ollamax-windows-${arch}-portable.${ext}"
    },
    "afterPack": "./scripts/afterPack.js"
  }
}
