# =====================================================================
# Ollama-Forge website / account backend — environment variables
# Copy to `.env.local` for local dev; set the same keys in Vercel for prod.
# NEVER commit the filled-in file. The GitHub client secret and the JWT/Auth
# secrets must exist ONLY on the server (Vercel env), never in any client.
# =====================================================================

# --- Auth.js (NextAuth) core ---
# Generate with:  openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-32-byte-random-string

# Public base URL of THIS site. Local: http://localhost:3000  Prod: https://your-domain
# Auth.js uses this to build callback URLs.
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- GitHub OAuth App (identity provider) ---
# From https://github.com/settings/developers → "New OAuth App".
# Add THREE callback URLs (GitHub OAuth Apps allow multiple):
#   <AUTH_URL>/api/auth/callback/github   (primary sign-in)
#   <AUTH_URL>/api/link/callback          (explicit account linking)
#   <AUTH_URL>/api/star/callback          (opt-in starring elevated scope)
AUTH_GITHUB_ID=your-github-oauth-app-client-id
AUTH_GITHUB_SECRET=your-github-oauth-app-client-secret

# --- Google OAuth (second identity provider; Round 6) ---
# Google Cloud Console → APIs & Services → Credentials → OAuth client (Web).
# Authorized redirect URIs:
#   <AUTH_URL>/api/auth/callback/google   (primary sign-in)
#   <AUTH_URL>/api/link/callback          (explicit account linking)
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# --- App tokens issued to the DESKTOP app (our own JWTs, not GitHub's) ---
# Separate secret from AUTH_SECRET so web-session and desktop-token signing keys
# are independent. Generate with: openssl rand -base64 32
APP_JWT_SECRET=replace-me-with-another-32-byte-random-string

# --- Database (Neon serverless Postgres recommended) ---
# Neon: https://neon.tech → project → connection string (pooled).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Central Hub ingestion (server-side GitHub catalog) ---
# A GitHub token used ONLY to raise the API rate limit for Hub catalog
# ingestion (Search API + repo metadata). LEAST PRIVILEGE: a fine-grained PAT
# with read-only access to PUBLIC repos (no write, no private). Never exposed to
# clients. Without it, ingestion falls back to the 60/hr unauthenticated limit.
GITHUB_INGEST_TOKEN=

# Protects the scheduled catalog-refresh endpoint (/api/hub/refresh). Set the
# same value in your cron/Vercel Cron config as a Bearer token.
CRON_SECRET=

# --- Durable, global rate limiting (recommended for scale) ---
# Upstash Redis REST creds. When present, auth/star/hub limits are enforced
# GLOBALLY across all serverless instances; otherwise a per-instance in-memory
# limiter is used (fine for dev, weak at scale).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- OAuth scope policy (informational; scopes are set in code) ---
# Identity login (Round 4): read-only  ->  read:user user:email
# Starring (opt-in only, Round 5)     ->  public_repo, requested ONLY when a
#   user explicitly chooses to "Support these maintainers". Never at login.

# --- Downloads (Round 7: unsigned bundles on a PUBLIC releases repo) ---
# Download URLs are built deterministically as:
#   <NEXT_PUBLIC_RELEASES_REPO>/releases/latest/download/<asset>
# so they don't change per version. The asset names are fixed in
# src/lib/downloads.ts. Defaults to the public releases repo if unset; override
# only if you host the binaries elsewhere. NEXT_PUBLIC_* are BUILD-TIME on
# Vercel — set then REDEPLOY.
NEXT_PUBLIC_RELEASES_REPO=https://github.com/pranayrishi/ollamax-releases

# Source repo (private) — used for "view on GitHub" links, NOT for downloads.
NEXT_PUBLIC_GITHUB_REPO=https://github.com/pranayrishi/ollamax
